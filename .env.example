# =============================================================================
# AIAC 2.0 Environment Configuration
# =============================================================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_DB=alpha_gpt

# Redis (for Celery and SSE)
REDIS_URL=redis://localhost:6379/0

# WorldQuant BRAIN Platform
BRAIN_EMAIL=your_email@example.com
BRAIN_PASSWORD=your_brain_password

# LLM Configuration
# Provider: "openai" (Qwen/DeepSeek/etc. via OpenAI-compat) or "anthropic" (Claude)
LLM_PROVIDER=openai

# OpenAI-compatible (DeepSeek/Qwen/SiliconFlow/Moonshot)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Anthropic Claude (set LLM_PROVIDER=anthropic to activate; uses prompt caching)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Optional — leave empty to use https://api.anthropic.com (official).
# Set to a proxy / mirror / compatible gateway when needed.
ANTHROPIC_BASE_URL=
# Extended thinking strength (Claude reasoning models — opus-4-7 family).
# Levels: disabled / low / medium / high / xhigh (default) / adaptive.
# Higher = better reasoning, but more tokens & latency. Sonnet/Haiku ignore.
ANTHROPIC_THINKING_EFFORT=xhigh

# Mining Defaults (optional)
DEFAULT_REGION=USA
DEFAULT_UNIVERSE=TOP3000
DEFAULT_DAILY_GOAL=4

# Quality Thresholds (optional)
SHARPE_MIN=1.5
TURNOVER_MAX=0.7
FITNESS_MIN=1.0
MAX_CORRELATION=0.7

# Logging
LOG_LEVEL=INFO
