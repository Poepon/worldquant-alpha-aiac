*.pyc
.env
.env.bak*
.env.*.bak
__pycache__
frontend/node_modules
frontend/dist
venv
*.log
*.log.*
logs/

# Local process stderr/stdout from run.bat / nohup dev workflow.
# Repo-root dot-prefix files like .uvicorn.err / .celery.out / .frontend.err
# — regenerated on every process start, never source-of-truth.
# (`*.log` above already covers .log suffix; .err/.out need explicit pattern.)
/.*.err
/.*.out
.cursor/
.claude/
.cursorrules
.clauderules
.cursorignore
.claudeignore
.cursorignore
backend/alembic/versions/__pycache__/
backend/data/correlation_cache/
# Local data artifacts under backend/data — never source-of-truth (the committed
# seeds are .json/.yaml/.parquet). Top-level sqlite + vendor csv dumps stay local.
backend/data/*.db
backend/data/*.sqlite
backend/data/*.csv
/.vs

# local probe / experiment scripts (kept out of repo)
.brain-probe.py
.refresh-corr-cache.py
.test-fallback.py
.test-pnl-fetch.py
.test-w2-island.py
.test-w3-upsert.py
.test-w6-fewshot.py
.test-w6-revised.py
.harvest-pass.py
.backfill-metadata.py

# backfill dryrun output (regenerated by backfill_factor_tier_dryrun.py)
backfill_plan.json

# Celery beat scheduler state (regenerated on every beat start)
celerybeat-schedule
celerybeat-schedule.bak
celerybeat-schedule.dat
celerybeat-schedule.dir
celerybeat.pid
/.cursor/debug.log
backups/
/docs/alpha_health_check
/docs/hypothesis_health_check
/docs/llm_op_monitor
/docs/macro_narratives
/docs/negative_knowledge
/docs/phase3_readiness
/docs/pillar_balance
/docs/regime_state
# iqc_marginal_audit.py auto-writes timestamped reports here; ignore them but
# keep the one audit referenced as the documented --from-audit example.
/docs/iqc_audit/*
!/docs/iqc_audit/audit_2026-05-11_1231.json
!/docs/iqc_audit/audit_2026-05-11_1231.md
# 脚本在 docs/ 顶层生成的带日期产物 — 不入库。
# 来源:backlog_drain_rank.py / _scan_dirty_data_*.py / benchmark_llm_alpha_quality.py / _transfer_harvest_*.py
/docs/backlog_drain_*.json
/docs/backlog_drain_*.md
/docs/dirty_data_scan_*.json
/docs/dirty_data_scan_*.md
/docs/llm_alpha_quality_benchmark_*.json
/docs/transfer_harvest_*.json

# R13 factor-data vendor sources — large binaries, re-downloadable from
# the vendor; the derived parquet + cleaned CSVs are committed instead.
/data/AQR_*.xlsx
